# Cloudflare R2 配置
# 账户 ID
R2_ACCOUNT_ID=5916e35f85cd5615d987c9b8a35398f8
# S3 Compatible Access Key ID (32 characters, from R2 S3 API credentials)
R2_ACCESS_KEY_ID=your_access_key_id
# S3 Compatible Secret Access Key (64 characters, from R2 S3 API credentials)
R2_SECRET_ACCESS_KEY=your_secret_access_key
# 存储桶名称
R2_BUCKET=secporbe
# 自定义访问域名
R2_BASE_URL=https://data.semove.ccwu.cc

# GitCode 配置
GITCODE_TOKEN=your_gitcode_token

# 阿里云 OSS 配置（备用，已切换到 R2）
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=secprobe