{
  "name": "mlps-assessment-tool",
  "version": "1.2.3",
  "description": "JSecProbe - 等级保护现场测评系统",
  "main": "dist-electron/main/index.js",
  "author": "景景",
  "copyright": "Copyright (c) 2025 景景. All rights reserved.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:portable": "vue-tsc --noEmit && vite build && electron-builder --win portable",
    "rebuild": "electron-rebuild",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate:sqlite --schema=electron/db/schema.ts --out=electron/db/migrations",
    "db:migrate": "tsx electron/db/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "crypto-js": "^4.2.0",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.30.0",
    "electron-log": "^5.1.0",
    "electron-updater": "^6.1.0",
    "element-plus": "^2.7.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "pinia": "^2.1.7",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tesseract.js": "^5.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "drizzle-kit": "^0.20.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "sass": "^1.71.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "com.mlps.assessment",
    "productName": "JSecProbe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron",
      "dist-renderer"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "./",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JSecProbe"
    }
  }
}
