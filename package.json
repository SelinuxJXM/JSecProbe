{
  "name": "mlps-assessment-tool",
  "version": "2.0.7",
  "description": "JSecProbe - 等级保护现场测评系统",
  "main": "dist-electron/main/index.js",
  "author": "景景",
  "copyright": "Copyright (c) 2025 景景. All rights reserved.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:win:full": "node scripts/build-win.js",
    "build:portable": "vue-tsc --noEmit && vite build && electron-builder --win portable",
    "rebuild": "electron-rebuild",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate:sqlite --schema=electron/db/schema.ts --out=electron/db/migrations",
    "db:migrate": "tsx electron/db/migrate.ts",
    "upload:r2": "node scripts/upload-to-r2.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "compressing": "^2.1.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.30.0",
    "echarts": "^6.1.0",
    "electron-log": "^5.1.0",
    "electron-updater": "^6.1.0",
    "element-plus": "^2.7.0",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pinia": "^2.1.7",
    "sharp": "^0.35.3",
    "tesseract.js": "^5.0.0",
    "vue": "^3.4.0",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "drizzle-kit": "^0.20.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "rcedit": "^5.0.1",
    "sass": "^1.71.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "com.mlps.assessment",
    "productName": "JSecProbe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron",
      "dist-renderer"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "./",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "publish": {
      "provider": "github",
      "owner": "SelinuxJXM",
      "repo": "JSecProbe",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JSecProbe"
    }
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "@parcel/watcher@2.5.6": true,
    "better-sqlite3@11.10.0": true,
    "core-js@3.49.0": true,
    "electron@29.4.6": true,
    "es5-ext@0.10.64": true,
    "lzma-native@8.0.6": true,
    "tesseract.js@5.1.1": true,
    "vue-demi@0.14.10": true
  }
}
